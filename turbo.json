{
  "$schema": "https://turborepo.com/schema.v2.json",
  "globalEnv": [
    "DATABASE_URL",
    "AUTH_TRUST_HOST",
    "SMTP_HOST",
    "SMTP_PORT",
    "SMTP_SECURE",
    "SMTP_USER",
    "SMTP_PASS",
    "EMAIL_FROM",
    "ADMIN_EMAIL",
    "ADMIN_PASSWORD",
    "NODE_ENV",
    "REDIS_URL",
    "AUTH_SECRET",
    "NEXTAUTH_SECRET",
    "AUTH_URL",
    "NEXTAUTH_URL",
    "ARLIST_CLIENT_ID",
    "ARLIST_CLIENT_SECRET",
    "GITHUB_ID",
    "GITHUB_SECRET",
    "PORT",
    "CODE_RUNNER_CONCURRENCY",
    "CODE_RUNNER_TIMEOUT_MS",
    "CODE_RUNNER_MEMORY_LIMIT",
    "CODE_RUNNER_CPU_LIMIT",
    "CODE_RUNNER_MAX_OUTPUT_BYTES",
    "CODE_RUNNER_MAX_QUEUE_DEPTH"
  ],
  "globalDependencies": [".env", ".env.*"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "@repo/db#db:generate"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "env": [
        "VERCEL",
        "VERCEL_URL",
        "VERCEL_PROJECT_PRODUCTION_URL",
        "VERCEL_ENV",
        "STAGING",
        "NODE_ENV",
        "REDIS_URL",
        "GH_TOKEN",
        "GITHUB_ID",
        "GITHUB_SECRET",
        "UPLOADTHING_SECRET",
        "UPLOADTHING_APP_ID",
        "EDGE_CONFIG",
        "NEXTAUTH_SECRET",
        "AUTH_SECRET",
        "NEXTAUTH_URL",
        "AUTH_REDIRECT_PROXY_URL",
        "RESEND_API_KEY",
        "SENTRY_AUTH_TOKEN",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "PORT",
        "USERNAME",
        "PASSWORD",
        "CI",
        "CRON_SECRET",
        "MAILCHIMP_API_KEY",
        "MAILCHIMP_AUDIENCE_ID",
        "MAILCHIMP_API_SERVER",
        "NEXT_PUBLIC_ALGOLIA_API_KEY",
        "NEXT_PUBLIC_ALGOLIA_APP_ID",
        "ARLIST_CLIENT_ID",
        "ARLIST_CLIENT_SECRET"
      ]
    },
    "topo": {
      "dependsOn": ["^topo"]
    },
    "//#format": {
      "outputs": ["node_modules/.cache/prettiercache"],
      "outputLogs": "errors-only"
    },
    "format": {
      "dependsOn": ["@repo/db#db:generate", "^topo"],
      "outputs": ["node_modules/.cache/prettiercache"],
      "outputLogs": "errors-only"
    },
    "//#format:fix": {
      "outputs": ["node_modules/.cache/prettiercache"],
      "outputLogs": "errors-only"
    },
    "format:fix": {
      "dependsOn": ["@repo/db#db:generate", "^topo"],
      "outputs": ["node_modules/.cache/prettiercache"],
      "outputLogs": "errors-only"
    },
    "//#lint": {
      "outputs": ["node_modules/.cache/.eslintcache"],
      "outputLogs": "errors-only"
    },
    "lint": {
      "dependsOn": ["@repo/db#db:generate", "^topo"],
      "outputs": ["node_modules/.cache/.eslintcache"],
      "outputLogs": "errors-only"
    },
    "//#lint:fix": {
      "dependsOn": ["@repo/db#db:generate", "^topo"],
      "outputs": ["node_modules/.cache/.eslintcache"],
      "outputLogs": "errors-only"
    },
    "lint:fix": {
      "dependsOn": ["@repo/db#db:generate", "^topo"],
      "outputs": ["node_modules/.cache/.eslintcache"],
      "outputLogs": "errors-only"
    },
    "typecheck": {
      "dependsOn": ["@repo/db#db:generate", "^topo"],
      "outputLogs": "errors-only"
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "dependsOn": ["@repo/db#db:generate"],
      "persistent": true,
      "cache": false
    },
    "start": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    },
    "test:e2e": {
      "outputs": ["playwright-report/**"],
      "env": [
        "AUTH_SECRET",
        "DATABASE_URL",
        "GITHUB_ID",
        "GITHUB_SECRET",
        "NEXTAUTH_SECRET",
        "NEXTAUTH_URL"
      ]
    },
    "test:e2e:ui": {
      "outputs": ["playwright-report/**"],
      "env": [
        "AUTH_SECRET",
        "DATABASE_URL",
        "GITHUB_ID",
        "GITHUB_SECRET",
        "NEXTAUTH_SECRET",
        "NEXTAUTH_URL"
      ]
    },
    "test:e2e:inspector": {
      "outputs": ["playwright-report/**"]
    }
  }
}
